# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-app-name.onrender.com

# Database (SQLite for MVP, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_USERNAME=your_bot_username_without_at
TELEGRAM_BOT_DISPLAY_NAME=Telegram Bot
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-here
APP_DISPLAY_NAME=Telegram Workflow Bot

# Manual API protection
API_AUTH_TOKEN=your-manual-api-token-here

# Django Superuser (for deployment)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme

# Google service account
GOOGLE_SERVICE_ACCOUNT_FILE=/etc/secrets/credentials.json

# Public app URL used to build Telegram Mini App / fallback links.
# Must be HTTPS and must not end with a slash.
APP_BASE_URL=https://your-app-name.onrender.com

# Google Drive media storage
# Use a Shared Drive folder or a folder owned by an account with quota.
MEDIA_STORAGE_PROVIDER=google_drive
MEDIA_MAX_FILE_SIZE_MB=20
FILE_UPLOAD_MAX_MEMORY_SIZE=0
GOOGLE_DRIVE_MEDIA_FOLDER_ID=your-shared-drive-folder-id

# Order Approval Mini App and uploads
ORDER_APPROVAL_WEBAPP_ENABLED=True
ORDER_APPROVAL_MINI_APP_SHORT_NAME=orderapproval
ORDER_APPROVAL_WEBAPP_REQUIRE_TELEGRAM_AUTH=True
ORDER_APPROVAL_WEBAPP_AUTH_MAX_AGE_SECONDS=86400
ORDER_APPROVAL_MAX_FILES_PER_SLOT=10
ORDER_APPROVAL_MAX_TOTAL_UPLOAD_MB=60
ORDER_APPROVAL_IMAGE_PREVIEWS_ENABLED=False
ORDER_APPROVAL_IMAGE_PREVIEW_LIMIT=3
ORDER_APPROVAL_BRANCH_CHOICES=BIOGAS UNIT,EMBU,NAKURU,WEST NAIROBI

# Jawabu / Farmers / FCA review Mini Apps
FARMUP_MINI_APP_SHORT_NAME=farmup
FCAUP_MINI_APP_SHORT_NAME=fcaup
FCA_BATCH_MAX_FILE_SIZE_MB=10

# Portal Mini App
PORTAL_MINI_APP_SHORT_NAME=portal
PORTAL_WEBAPP_REQUIRE_TELEGRAM_AUTH=True
PORTAL_WEBAPP_AUTH_MAX_AGE_SECONDS=86400

# SPIN / CRB Mini App and uploads
SPIN_MINI_APP_SHORT_NAME=spin
SPIN_WEBAPP_REQUIRE_TELEGRAM_AUTH=True
SPIN_WEBAPP_AUTH_MAX_AGE_SECONDS=86400
SPIN_ANALYSTS=analyst_username,123456789
SPIN_MAX_FILES_PER_SLOT=2
SPIN_MAX_TOTAL_UPLOAD_MB=20

# TAT Tracker Mini App
TAT_TRACKER_MINI_APP_SHORT_NAME=tattracker
TAT_TRACKER_WEBAPP_REQUIRE_TELEGRAM_AUTH=True
TAT_TRACKER_WEBAPP_AUTH_MAX_AGE_SECONDS=86400

# Processing
DEDUPLICATION_WINDOW_MINUTES=5
BATCH_PROCESSING_DELAY=1
WHATSAPP_BATCH_MAX_MESSAGES=0
WHATSAPP_BATCH_ASYNC_THRESHOLD=100
WHATSAPP_BATCH_MAX_FILE_SIZE_MB=5
INVOICE_UPLOAD_MAX_FILE_SIZE_MB=8

# Group to spreadsheet/workflow routing is configured in Django admin:
# Core -> Group sheet configurations.
# Prefer admin configuration over env JSON for all current workflows.
# Legacy single-group/env JSON values are supported only for old deployments.
# GOOGLE_SHEET_ID=
# GOOGLE_SHEET_TAB_NAME=Complaints Register
# DEFAULT_GROUP_ID=default
# GROUP_MAPPING_JSON={}
# WORKFLOW_CONFIG_JSON={}
# SHEET_SCHEMA_JSON={}
# PARSER_RULES_JSON={}

# API Rate Limiting (optional)
RATELIMIT_ENABLE=False
RATELIMIT_PER_IP=100/h
